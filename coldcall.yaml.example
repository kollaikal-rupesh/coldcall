# ColdCall configuration
# Copy to coldcall.yaml and fill in your keys

# For demo mode, only OpenAI is needed
openai:
  api_key: ""

# For voice tests (coldcall test ws:// or lk://)
deepgram:
  api_key: ""

cartesia:
  api_key: ""

# LiveKit (coldcall test lk://room-name)
livekit:
  url: ""          # wss://your-project.livekit.cloud
  api_key: ""
  api_secret: ""

# Twilio (only for phone call tests)
twilio:
  account_sid: ""
  auth_token: ""

server:
  public_url: ""   # only needed for phone calls
  port: 8080

defaults:
  scenario: "dental-appointment"
  area_code: "415"
